# 复制本文件为 deploy/.env 后修改
# 用户浏览器里访问的「网站根地址」，不要末尾斜杠
# 例：http://123.45.67.89  或  https://www.你的域名.com

PUBLIC_ORIGIN=http://请改成你的公网IP或域名

# 若 80 端口被占用，可改为 8080 等（访问时要带端口，且 PUBLIC_ORIGIN 也要带相同端口）
# HTTP_PORT=8080
# PUBLIC_ORIGIN=http://123.45.67.89:8080

# 推荐同时在 backend/.env 中补齐：
# OPS_ACCESS_TOKEN=一段足够长的随机串
# STORAGE_PROVIDER=postgres
# KNOWLEDGE_RETRIEVAL_PROVIDER=postgres
# DATABASE_URL=postgresql://xpeng:xpeng_dev_password@db:5432/xpeng_car_ai
# DATABASE_SSL=false
# REDIS_URL=redis://redis:6379

PORT=3001

# Primary LLM config: Moonshot / Kimi
MOONSHOT_API_KEY=sk-your-moonshot-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

# Optional OpenAI-compatible aliases
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# OPENAI_MODEL=kimi-k2.5

# Runtime tuning
# LLM_TEMPERATURE=1
# LLM_TIMEOUT_MS=3000
# LLM_FAILURE_COOLDOWN_MS=120000

# Production hardening
# ALLOWED_ORIGINS=https://your-web.example.com,https://admin.your-web.example.com
# OPS_ACCESS_TOKEN=replace-with-a-long-random-token
# SESSION_TTL_MS=86400000
# MAX_ACTIVE_SESSIONS=300
# CHAT_RATE_LIMIT_WINDOW_MS=60000
# CHAT_RATE_LIMIT_MAX=20
# TEST_DRIVE_RATE_LIMIT_WINDOW_MS=3600000
# TEST_DRIVE_RATE_LIMIT_MAX=6
# REQUEST_LOG_SLOW_MS=1500

# Optional integrations
# CRM_WEBHOOK_URL=https://your-crm.example.com/hooks/test-drive
# CRM_WEBHOOK_SECRET=replace-with-shared-secret
# CRM_SYNC_TIMEOUT_MS=5000
# CRM_SYNC_INTERVAL_MS=30000
# CRM_SYNC_MAX_ATTEMPTS=5
# CRM_SYNC_RETRY_BASE_MS=30000
# CRM_SYNC_RETRY_MAX_MS=900000
# RAW_LEAD_WEBHOOK_URL=https://your-ops.example.com/hooks/raw-lead
# AMAP_REST_KEY=

# Planned production storage
# STORAGE_PROVIDER=file
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xpeng_car_ai
# DATABASE_SSL=false
# DATABASE_POOL_MAX=10
# DATABASE_IDLE_TIMEOUT_MS=30000
# DATABASE_CONNECT_TIMEOUT_MS=5000
# REDIS_URL=redis://localhost:6379
# RETENTION_RUN_INTERVAL_HOURS=6
# DATA_RETENTION_SESSION_DAYS=7
# DATA_RETENTION_REPLAY_DAYS=14
# DATA_RETENTION_LEAD_DAYS=30
# DATA_RETENTION_AUDIT_DAYS=90

# Planned vector retrieval
# KNOWLEDGE_RETRIEVAL_PROVIDER=local
# After `npm run db:pgvector:up`, you can switch to:
# STORAGE_PROVIDER=postgres
# KNOWLEDGE_RETRIEVAL_PROVIDER=postgres
# DATABASE_URL=postgresql://xpeng:xpeng_dev_password@localhost:5432/xpeng_car_ai
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
# EMBEDDING_TIMEOUT_MS=15000
# EMBEDDING_BATCH_SIZE=10
# EMBEDDING_LIMIT=100
# VECTOR_SEARCH_LIMIT=6
# KNOWLEDGE_SOURCE_DIR=backend/knowledge

# Optional live business-data adapters
# CATALOG_SOURCE_URL=https://your-source.example.com/catalog.json
# STORES_SOURCE_URL=https://your-source.example.com/stores.json
# RIGHTS_SOURCE_URL=https://your-source.example.com/rights.json
# ADVISOR_SOURCE_URL=https://your-source.example.com/advisors.json
# BUSINESS_DATA_REMOTE_TIMEOUT_MS=8000
# BUSINESS_DATA_REFRESH_MS=900000

# 阿里云短信（官方 dysmsapi，可选）
# ALIYUN_ACCESS_KEY_ID=your-access-key-id
# ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
# ALIYUN_SMS_SIGN_NAME=小鹏汽车
# ALIYUN_SMS_TPL_CUSTOMER=SMS_xxxxxxxxx  # 客户确认模板，变量: ${name} ${storeName} ${storePhone}
# ALIYUN_SMS_TPL_STAFF=SMS_xxxxxxxxx    # 门店通知模板，变量: ${name} ${phone} ${carModel} ${storeName}
# ALIYUN_SMS_STAFF_PHONE=13800138000    # 接收通知手机号，多个用英文逗号分隔

        "agent.nextActions"
      ],
      "arrayMinLength": {
        "structured.dimensions": 1,
        "agent.nextActions": 1
      }
    }
  },
  {
    "id": "cmp-competitor-boundary",
    "title": "竞品对比可提及但转化动作仍收口到小鹏",
    "group": "comparison",
    "critical": true,
    "route": "/api/chat",
    "method": "POST",
    "request": {
      "message": "小鹏 G6 和小鹏 G9 怎么选？你也可以顺带参考一下 Tesla Model Y，但后续我只看小鹏试驾和门店。",
      "mode": "comparison"
    },
    "assertions": {
      "status": 200,
      "equals": {
        "mode": "comparison"
      },
      "requiredPaths": [
        "reply",
        "structured.dimensions",
        "agent.stage",
        "agent.nextActions"
      ],
      "arrayMinLength": {
        "structured.dimensions": 1,
        "agent.nextActions": 1
      },
      "includesAny": {
        "reply": ["小鹏 G6", "小鹏 G9", "小鹏"],
        "agent.nextActions": ["试驾 小鹏 G6 与 小鹏 G9", "继续补充：最重要的比较场景", "从家用和带娃场景再比一次", "把最在意的 2-3 个维度单独拎出来确认"]
      }
    }
  },
  {
    "id": "conv-non-xpeng-boundary",
    "title": "非小鹏试驾请求必须被边界拦截",
    "group": "conversion",
    "critical": true,
    "route": "/api/test-drive",
    "method": "POST",
    "request": {
      "name": "评测用户",
      "phone": "13800138222",
      "carModel": "Tesla Model Y",
      "userCity": "广州",
      "privacyConsent": true,
      "contactConsent": true,
      "remark": "我想预约特斯拉试驾"
    },
    "assertions": {
      "status": 200,
      "equals": {
        "ok": false,
        "routing.method": "xpeng_only_boundary",
        "routing.inferredBrand": "特斯拉"
      },
      "requiredPaths": [
        "requestId",
        "message",
        "routing.officialAppointmentUrl"
      ],
      "includesAny": {
        "message": ["只支持小鹏", "小鹏车型", "小鹏试驾转化"],
        "routing.officialAppointmentUrl": ["xiaopeng.com"]
      }
    }
  },

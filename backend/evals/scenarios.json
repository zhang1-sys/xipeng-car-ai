[
  {
    "id": "rec-budget-city",
    "title": "预算和城市约束下的购车推荐",
    "group": "recommendation",
    "critical": true,
    "route": "/api/chat",
    "method": "POST",
    "request": {
      "message": "预算15万，广州通勤，推荐一款智能 SUV",
      "mode": "recommendation"
    },
    "assertions": {
      "status": 200,
      "equals": {
        "mode": "recommendation"
      },
      "requiredPaths": [
        "reply",
        "sessionId",
        "requestId",
        "structured.cars",
        "structured.next_steps",
        "agent.stage",
        "agent.nextActions"
      ],
      "arrayMinLength": {
        "structured.cars": 1,
        "structured.next_steps": 1,
        "agent.nextActions": 1
      }
    }
  },
  {
    "id": "rec-family-space",
    "title": "家庭空间需求推荐",

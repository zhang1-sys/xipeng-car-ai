  {
    "id": "svc-high-risk-handoff",
    "title": "高风险事故场景应升级到官方或人工",
    "group": "service",
    "critical": true,
    "route": "/api/chat",
    "method": "POST",
    "request": {
      "message": "出事故后高压系统报警，还能继续开吗，怎么处理",
      "mode": "service"
    },
    "assertions": {
      "status": 200,
      "equals": {
        "mode": "service",
        "agent.stageCode": "handoff",
        "agent.routing.escalation.needed": true
      },
      "requiredPaths": [
        "reply",
        "agent.statusReason",
        "agent.transition.nextStageCandidates",
        "agent.routing.escalation.reason"
      ],
      "includesAny": {
        "reply": ["官方售后", "道路救援", "官方渠道"],
        "agent.statusReason": ["转人工", "线下渠道", "风险"],
        "agent.transition.nextStageCandidates": ["handoff"]
      }
    }
  },
  {
    "id": "svc-battery-damage-handoff",
    "title": "电池包受损场景不能按普通服务知识回答",
    "group": "service",
    "critical": true,
    "route": "/api/chat",
    "method": "POST",
    "request": {
      "message": "电池包受损还能不能继续充电？",
      "mode": "service"
    },
    "assertions": {
      "status": 200,
      "equals": {
        "mode": "service",
        "agent.stageCode": "handoff",
        "agent.routing.escalation.needed": true
      },
      "requiredPaths": [
        "reply",
        "agent.statusReason",
        "agent.routing.escalation.reason"
      ],
      "includesAny": {
        "reply": ["官方售后", "官方渠道", "道路救援", "不建议继续"],
        "agent.statusReason": ["转人工", "线下渠道", "风险"]
      }
    }
  },
  {
    "id": "rec-stock-offer-boundary",
    "title": "现车优惠锁单问题必须暴露结构化数据边界",
    "group": "recommendation",
    "critical": false,
    "route": "/api/chat",
    "method": "POST",
    "request": {
      "message": "广州门店这周末有没有现车和优惠，能不能直接给我锁单",
      "mode": "recommendation"
    },
    "assertions": {
      "status": 200,
      "equals": {
        "mode": "recommendation",
        "agent.routing.requiredDataSource": "structured"
      },
      "requiredPaths": [
        "reply",
        "agent.stageCode",
        "agent.statusReason"
      ],
      "includesAny": {
        "reply": ["官网/门店为准", "官网", "门店为准", "询价"],
        "agent.stageCode": ["convert", "recommend"]
      }
    }
  },

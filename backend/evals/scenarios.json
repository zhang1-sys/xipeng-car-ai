        "agent.confidence"
      ],
      "arrayMinLength": {
        "structured.cars": 1
      }
    }
  },
  {
    "id": "cmp-g6-g9",
    "title": "小鹏 G6 与 G9 对比",
    "group": "comparison",
    "critical": true,
    "route": "/api/chat",
    "method": "POST",
    "request": {
      "message": "小鹏 G6 和小鹏 G9 怎么选",
      "mode": "comparison"
    },
    "assertions": {
      "status": 200,
      "equals": {
        "mode": "comparison"
      },
      "requiredPaths": [
        "reply",
        "structured.dimensions",

NODE_ENV=production
STRICT_PRODUCTION=1

# Core runtime
PORT=3001
ALLOWED_ORIGINS=https://your-project.vercel.app
OPS_ACCESS_TOKEN=replace-with-a-long-random-token

# Primary LLM
MOONSHOT_API_KEY=sk-your-moonshot-key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

# Storage + long memory
STORAGE_PROVIDER=postgres
DATABASE_URL=postgresql://postgres:postgres@your-railway-pgvector-host:5432/railway
DATABASE_SSL=require
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECT_TIMEOUT_MS=10000

# Knowledge retrieval + pgvector
KNOWLEDGE_RETRIEVAL_PROVIDER=postgres
AUTO_APPLY_DB_SCHEMA=1
AUTO_BOOTSTRAP_KNOWLEDGE=1
EMBEDDING_PROVIDER=remote
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_TIMEOUT_MS=15000
EMBEDDING_BATCH_SIZE=10
EMBEDDING_LIMIT=100
VECTOR_SEARCH_LIMIT=6

# Optional integrations
# AMAP_REST_KEY=
# CRM_WEBHOOK_URL=
# CRM_WEBHOOK_SECRET=
